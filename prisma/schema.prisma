// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts         Account[]
  sessions         Session[]
  profile          UserProfile?
  keywords         UserKeyword[]
  paperActions     UserPaperAction[]
  recommendations  Recommendation[]
  dailyDigests     DailyDigest[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model UserProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  digestEmail String?
  digestTime  String  @default("09:00")
  timezone    String  @default("Asia/Tokyo")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserKeyword {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  term      String
  type      KeywordType @default(CORE)
  weight    Float    @default(1.0)
  synonyms  String[] @default([])
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, term])
  @@index([userId, isActive])
}

enum KeywordType {
  CORE
  SUBFIELD
  EXCLUDE
}

model Paper {
  id          String   @id @default(cuid())
  doi         String?  @unique
  title       String
  titleNorm   String
  authors     String[]
  abstract    String?
  summaryJa   String?
  shortSummaryJa String?
  journal     String?
  publishedAt DateTime?
  year        Int?
  pdfUrl      String?
  sourceCount Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sources         PaperSource[]
  recommendations Recommendation[]
  userActions     UserPaperAction[]
}

model PaperSource {
  id         String   @id @default(cuid())
  paperId    String
  paper      Paper    @relation(fields: [paperId], references: [id], onDelete: Cascade)
  source     SourceType
  externalId String
  url        String?
  rawData    Json?
  fetchedAt  DateTime @default(now())

  @@unique([source, externalId])
  @@index([paperId])
}

enum SourceType {
  ARXIV
  CROSSREF
  PUBMED
  WEB_OF_SCIENCE
  SCOPUS
  MOCK
}

model Recommendation {
  id                 String   @id @default(cuid())
  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  paperId            String
  paper              Paper    @relation(fields: [paperId], references: [id], onDelete: Cascade)
  runId              String?
  run                RecommendationRun? @relation(fields: [runId], references: [id])
  date               DateTime @db.Date
  rank               Int
  keywordMatchScore  Float    @default(0)
  recencyScore       Float    @default(0)
  feedbackScore      Float    @default(0)
  ideaSignalScore    Float    @default(0)
  totalScore         Float    @default(0)
  matchedKeywords    String[] @default([])
  reasonTemplate     String?
  createdAt          DateTime @default(now())

  @@unique([userId, paperId, date])
  @@index([userId, date])
}

model UserPaperAction {
  id         String     @id @default(cuid())
  userId     String
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  paperId    String
  paper      Paper      @relation(fields: [paperId], references: [id], onDelete: Cascade)
  action     ActionType
  createdAt  DateTime   @default(now())

  @@unique([userId, paperId, action])
  @@index([userId, action])
}

enum ActionType {
  READ
  NOT_INTERESTED
  BOOKMARKED
  IDEA_GENERATED
}

model DailyDigest {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date        DateTime @db.Date
  emailSentAt DateTime?
  emailTo     String?
  status      DigestStatus @default(PENDING)
  paperCount  Int      @default(0)
  error       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, date])
}

enum DigestStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

model RecommendationRun {
  id          String   @id @default(cuid())
  type        RunType
  status      RunStatus @default(RUNNING)
  startedAt   DateTime @default(now())
  completedAt DateTime?
  papersCollected Int  @default(0)
  papersDeduped   Int  @default(0)
  recommendationsGenerated Int @default(0)
  error       String?
  log         String?

  recommendations Recommendation[]
}

enum RunType {
  DAILY_COLLECT
  WEEKLY_RETRAIN
}

enum RunStatus {
  RUNNING
  COMPLETED
  FAILED
}
